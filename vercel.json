{
  "rewrites": [
    { "source": "/", "has": [{ "type": "host", "value": "sundaysunday.colectivo.live" }], "destination": "/sundaysunday.html" },
    { "source": "/e/:slug", "destination": "/evento.html?e=:slug" },
    { "source": "/invite/:token", "destination": "/invite.html?t=:token" },
    { "source": "/:slug", "destination": "/org.html?slug=:slug" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
