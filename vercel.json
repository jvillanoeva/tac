{
  "rewrites": [
    { "source": "/e/:slug", "destination": "/evento.html?e=:slug" },
    { "source": "/invite/:token", "destination": "/invite.html?t=:token" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
